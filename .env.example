# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase
# (Project Settings > API no painel do Supabase)

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica-aqui

# Login único da plataforma (tela em /login). Nunca prefixar com NEXT_PUBLIC_.
ADMIN_USERNAME=defina-o-usuario-aqui
ADMIN_PASSWORD=defina-a-senha-aqui
# Gere um valor aleatório novo, por exemplo: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=gere-um-valor-aleatorio-longo-aqui
